########################################
# OpenAI / 模型
########################################
OPENAI_API_KEY=sk-XXXX
EMBED_MODEL=text-embedding-3-small

# Reranker 與 Chat 模型（實際使用的名稱會進 cache key）
RERANK_PROVIDER=local
RERANK_MODEL=BAAI/bge-reranker-v2-m3 
RERANK_TOP_K=3                                         # 最終餵 LLM 幾個片段
CHAT_MODEL=gpt-4o-mini

########################################
# 檔案路徑（以目前工作目錄為基準）
########################################
DATA_DIR=backend/data                                  # 要以目前工作目錄為基準
INDEX_PATH=backend/data/index.faiss                    # 要以目前工作目錄為基準
DOCSTORE_PATH=backend/data/docstore.jsonl              # 要以目前工作目錄為基準

########################################
# 檢索 / 組裝 / 回答參數
########################################
TOP_K=3
MAX_CONTEXT_CHARS=1800
ANSWER_MAX_TOKENS=400

########################################
# 環境 / 速率限制
########################################
APP_ENV=production
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_PER_USER_PER_MIN=60
RATE_LIMIT_BURST=10
DISABLE_RATE_LIMIT=0

########################################
# Cache 相關
########################################
# 後端: memory | redis
CACHE_BACKEND=redis
# 命名空間（避免 key 汙染，建議專案名）
CACHE_NAMESPACE=ragqa
# 預設 TTL (秒)
CACHE_TTL_SECONDS=3600
# 版本號（會進 cache key，改版自然失效）
INDEX_VERSION=v1

########################################
# Redis（只有當 CACHE_BACKEND=redis 才需要）
########################################
# Redis 連線字串（只有當 CACHE_BACKEND=redis 時才需要）
REDIS_URL=redis://localhost:6379/0